# Copy to /etc/nut/upsd.users on rke2-node-12 and replace the placeholder passwords.
# Real values are generated at install time and stored in 1Password (not committed).
#   admin          - full control (SET vars / run instant commands)
#   upsmon_remote  - login used by the other RKE2 nodes' upsmon (secondary)
#   monuser        - login Synology DSM uses by default for a network UPS server
[admin]
    password = __ADMIN_PW__
    actions = SET
    instcmds = ALL

[upsmon_remote]
    password = __UPSMON_REMOTE_PW__
    upsmon slave

[monuser]
    password = __MONUSER_PW__
    upsmon slave
