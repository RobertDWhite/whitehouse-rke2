                  { "options": { "OutOfSync": { "color": "yellow", "index": 1, "text": "OutOfSync" } }, "type": "value" },
                  { "options": { "Unknown": { "color": "semi-dark-gray", "index": 2, "text": "Unknown" } }, "type": "value" }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              }
            ]
          }
