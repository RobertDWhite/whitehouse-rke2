          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "health_status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "Healthy": { "color": "green", "index": 0, "text": "Healthy" } }, "type": "value" },
                  { "options": { "Degraded": { "color": "red", "index": 1, "text": "Degraded" } }, "type": "value" },
                  { "options": { "Missing": { "color": "yellow", "index": 2, "text": "Missing" } }, "type": "value" },
                  { "options": { "Unknown": { "color": "semi-dark-gray", "index": 3, "text": "Unknown" } }, "type": "value" },
                  { "options": { "Progressing": { "color": "blue", "index": 4, "text": "Progressing" } }, "type": "value" },
                  { "options": { "Suspended": { "color": "orange", "index": 5, "text": "Suspended" } }, "type": "value" }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "sync_status" },
