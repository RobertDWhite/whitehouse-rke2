      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "topk(25,\n  sum by (client_ip) (\n    count_over_time(\n      {namespace=\"envoy-gateway-system\", container=\"envoy\"}\n      | json\n      | __error__=\"\"\n      | authority=~\"$hostname\"\n      | label_format client_ip=`{{ regexReplaceAll \",.*\" .x_forwarded_for \"\" }}`\n      [$__range]\n    )\n  )\n)",
          "hide": false,
          "legendFormat": "{{client_ip}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Top client IPs ($hostname)",
