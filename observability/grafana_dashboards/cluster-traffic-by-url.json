  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["envoy", "gateway", "traffic", "loki"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values({namespace=\"envoy-gateway-system\", container=\"envoy\"} | json | __error__=\"\", authority)",
        "hide": 0,
        "includeAll": true,
        "label": "Hostname",
        "multi": true,
        "name": "hostname",
        "options": [],
        "query": {
          "label": "authority",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "{namespace=\"envoy-gateway-system\", container=\"envoy\"} | json | __error__=\"\"",
          "type": 1
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
