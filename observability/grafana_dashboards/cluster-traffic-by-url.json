        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Envoy Gateway HTTP traffic breakdown by hostname, status code, latency, and client IP",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (authority) (\n  count_over_time(\n    {namespace=\"envoy-gateway-system\", container=\"envoy\"}\n    | json\n    | __error__=\"\"\n    | authority=~\"$hostname\"\n    [$__auto]\n  )\n)",
          "hide": false,
          "legendFormat": "{{authority}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Requests over time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 2,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "topk(20,\n  sum by (authority) (\n    count_over_time(\n      {namespace=\"envoy-gateway-system\", container=\"envoy\"}\n      | json\n      | __error__=\"\"\n      [$__range]\n    )\n  )\n)",
          "hide": false,
          "legendFormat": "{{authority}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Top hostnames by request count",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Status & Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#37872d", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "3xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#1f78c1", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#e0b400", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#c4162a", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "displayLabels": ["percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "pie",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(\n  count_over_time(\n    {namespace=\"envoy-gateway-system\", container=\"envoy\"}\n    | json\n    | __error__=\"\"\n    | authority=~\"$hostname\"\n    | response_code >= 200 | response_code < 300\n    [$__range]\n  )\n)",
          "hide": false,
          "legendFormat": "2xx",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(\n  count_over_time(\n    {namespace=\"envoy-gateway-system\", container=\"envoy\"}\n    | json\n    | __error__=\"\"\n    | authority=~\"$hostname\"\n    | response_code >= 300 | response_code < 400\n    [$__range]\n  )\n)",
          "hide": false,
          "legendFormat": "3xx",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(\n  count_over_time(\n    {namespace=\"envoy-gateway-system\", container=\"envoy\"}\n    | json\n    | __error__=\"\"\n    | authority=~\"$hostname\"\n    | response_code >= 400 | response_code < 500\n    [$__range]\n  )\n)",
          "hide": false,
          "legendFormat": "4xx",
          "queryType": "range",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(\n  count_over_time(\n    {namespace=\"envoy-gateway-system\", container=\"envoy\"}\n    | json\n    | __error__=\"\"\n    | authority=~\"$hostname\"\n    | response_code >= 500\n    [$__range]\n  )\n)",
          "hide": false,
          "legendFormat": "5xx",
          "queryType": "range",
          "refId": "D"
        }
      ],
      "title": "Status code breakdown ($hostname)",
      "type": "piechart"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 300 }
            ]
