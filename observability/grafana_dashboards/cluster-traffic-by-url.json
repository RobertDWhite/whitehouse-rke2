            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "options": {
        "legend": {
          "calcs": ["mean", "p95"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "quantile_over_time(0.50,\n  {\n    namespace=\"envoy-gateway-system\",\n    container=\"envoy\"\n  }\n  | json\n  | __error__=\"\"\n  | authority=~\"$hostname\"\n  | unwrap duration\n  [$__auto]\n) by (authority)",
          "hide": false,
          "legendFormat": "p50 {{authority}}",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "quantile_over_time(0.95,\n  {\n    namespace=\"envoy-gateway-system\",\n    container=\"envoy\"\n  }\n  | json\n  | __error__=\"\"\n  | authority=~\"$hostname\"\n  | unwrap duration\n  [$__auto]\n) by (authority)",
          "hide": false,
          "legendFormat": "p95 {{authority}}",
          "queryType": "range",
          "refId": "B"
        }
