      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(\n  rate(\n    {namespace=\"envoy-gateway-system\", container=\"envoy\"}\n    | json\n    | __error__=\"\"\n    | authority=~\"$hostname\"\n    [1m]\n  )\n) * 60",
          "hide": false,
          "legendFormat": "req/min",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Request rate ($hostname)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
