          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "response_code" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "custom.width", "value": 80 },
