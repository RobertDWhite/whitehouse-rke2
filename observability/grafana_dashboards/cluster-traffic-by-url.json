        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Field": true },
            "indexByName": {},
            "renameByName": {
              "client_ip": "Client IP",
              "Last *": "Requests"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [{ "desc": true, "displayName": "Requests" }]
          }
        }
      ],
      "type": "table"
    },
