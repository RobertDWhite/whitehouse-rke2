        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Conns",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(envoy_http_downstream_cx_active{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
