        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "HTTP Requests / Backend Cluster",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(envoy_cluster_upstream_rq_total{envoy_cluster_name=~\"$cluster\", pod=~\"$pod\"}[$__interval])) by (envoy_cluster_name)",
          "legendFormat": "{{ envoy_cluster_name }}",
          "interval": "2m",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "HTTP status code breakdown across all traffic",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "Requests",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx" },
            "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "3xx" },
            "properties": [ { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "HTTP Response Status Classes",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(envoy_http_downstream_rq_2xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[$__interval]))",
          "legendFormat": "2xx",
          "interval": "2m",
          "refId": "A"
        },
        {
          "expr": "sum(increase(envoy_http_downstream_rq_3xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[$__interval]))",
