    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Downstream request latency percentiles (client-facing). Helps assess SLA compliance.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "Latency (ms)",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [ { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [ { "id": "color", "value": { "fixedColor": "dark-blue", "mode": "fixed" } } ]
          },
