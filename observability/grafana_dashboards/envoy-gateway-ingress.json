{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "enable": true,
        "expr": "changes(envoy_server_live{pod=~\"$pod\"}[2m])",
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "limit": 100,
        "name": "Envoy Restarts",
        "step": "30s",
        "tagKeys": "pod",
        "titleFormat": "Envoy Restarted"
      }
    ]
  },
  "description": "Envoy Gateway Ingress monitoring — replacement for Nginx Ingress Prometheus NextGen dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total number of requests made in the selected time range",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Requests (period)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(envoy_http_downstream_rq_total{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[${__range_s}s]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Percentage of successful requests over the entire period. Ignoring 404s (normal for scanners/probes).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "% Success (period)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(envoy_http_downstream_rq_2xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[${__range_s}s]) + increase(envoy_http_downstream_rq_3xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[${__range_s}s])) / clamp_min(sum(increase(envoy_http_downstream_rq_total{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[${__range_s}s])) - sum(increase(envoy_http_downstream_rq_4xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[${__range_s}s])) + sum(increase(envoy_http_downstream_rq_2xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[${__range_s}s]) + increase(envoy_http_downstream_rq_3xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[${__range_s}s])),1)",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current active downstream connections",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
