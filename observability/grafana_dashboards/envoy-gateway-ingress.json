      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "% Success (2m)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(envoy_http_downstream_rq_2xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[2m]) + rate(envoy_http_downstream_rq_3xx{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[2m])) / clamp_min(sum(rate(envoy_http_downstream_rq_total{envoy_http_conn_manager_prefix=~\"$listener\", pod=~\"$pod\"}[2m])),0.001)",
          "legendFormat": "",
          "refId": "A"
