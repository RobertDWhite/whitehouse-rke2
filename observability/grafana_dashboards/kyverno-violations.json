        {
          "datasource": { "type": "prometheus", "uid": "ffbp5qeorery8b" },
          "expr": "sum(increase(kyverno_admission_requests_total{allowed=\"false\"}[24h]))",
          "instant": true,
          "legendFormat": "denied",
          "refId": "A"
