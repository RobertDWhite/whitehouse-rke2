      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}, "unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 34}, "id": 56,
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "showUnfilled": true},
      "targets": [{"expr": "topk(10, tautulli_user_duration_seconds)", "legendFormat": "{{user}}"}],
      "title": "Top Users (30 Days — Watch Time)", "type": "bargauge"
    },

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 42}, "id": 104, "title": "Server", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "displayMode": "auto"}}, "overrides": []},
      "gridPos": {"h": 3, "w": 24, "x": 0, "y": 43}, "id": 11,
      "options": {"showHeader": true},
      "targets": [{"expr": "tautulli_server_info", "format": "table", "instant": true}],
      "title": "Server Info",
      "transformations": [
        {"id": "labelsToFields"},
        {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "instance": true, "job": true}, "renameByName": {"plex_name": "Server", "plex_platform": "Platform", "plex_version": "Plex Version", "tautulli_version": "Tautulli Version"}}}
      ],
      "type": "table"
    }
