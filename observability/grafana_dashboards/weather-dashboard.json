{
  "title": "Weather Dashboard",
  "uid": "weather-dashboard",
  "tags": ["weather", "app"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "ds",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active NWS Alerts",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "weather_active_alerts",
          "legendFormat": "{{severity}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 2,
      "title": "Storm Cells Active",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [{ "expr": "weather_active_storm_cells" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Tornado Warnings",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        { "expr": "weather_active_alerts{severity=\"Extreme\"}", "legendFormat": "extreme" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Local Storm Reports (last 2h)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "weather_active_lsrs", "legendFormat": "{{category}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 5,
      "title": "Request Rate (req/s by route)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{job=\"weather-api\",handler!~\"/health.*|/metrics\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "title": "Request Latency p95 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket{job=\"weather-api\",handler!~\"/health.*|/metrics\"}[5m]))) * 1000",
          "legendFormat": "{{handler}} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (source) (rate(weather_cache_hits_total[5m])) / (sum by (source) (rate(weather_cache_hits_total[5m])) + sum by (source) (rate(weather_cache_misses_total[5m])))",
          "legendFormat": "{{source}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 8,
      "title": "AI Briefings (rate by source)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (source, model) (rate(weather_briefing_generated_total[15m]))",
          "legendFormat": "{{source}} / {{model}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Briefing Generation Time (p50/p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(weather_briefing_duration_seconds_bucket[15m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(weather_briefing_duration_seconds_bucket[15m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 10,
      "title": "Webhook Deliveries",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(weather_webhook_deliveries_total[15m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Time-Machine Snapshots",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "rate(weather_snapshots_written_total[5m]) * 60", "legendFormat": "written/min" },
        { "expr": "rate(weather_snapshot_errors_total[5m]) * 60", "legendFormat": "errors/min" }
      ]
    },
    {
      "id": 12,
      "title": "Pod CPU + Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"weather\",container=~\"weather-api|weather-ui\"}[5m]))",
          "legendFormat": "{{pod}} cpu (cores)"
        },
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"weather\",container=~\"weather-api|weather-ui\"}) / 1024 / 1024",
          "legendFormat": "{{pod}} mem (MiB)"
        }
      ]
    }
  ]
}
